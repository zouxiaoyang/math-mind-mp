/* ===========================
   Math Mind — Global Styles
   Dark theme · Neon accents
   =========================== */

page {
  background-color: #f7f7f7;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, sans-serif;
  font-size: 28rpx;
  color: #333;
}

/* ---- layout helpers ---- */
.container {
  padding: 32rpx;
  box-sizing: border-box;
}

.flex {
  display: flex;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.gap-s { gap: 16rpx; }
.gap-m { gap: 24rpx; }

/* ---- spacing helpers ---- */
.mt-s { margin-top: 16rpx; }
.mt-m { margin-top: 24rpx; }
.mt-l { margin-top: 32rpx; }
.mb-s { margin-bottom: 16rpx; }
.mb-m { margin-bottom: 24rpx; }
.mb-l { margin-bottom: 32rpx; }
.ml-s { margin-left: 16rpx; }
.mr-s { margin-left: 16rpx; }
.p-s { padding: 16rpx; }
.p-m { padding: 24rpx; }
.p-l { padding: 32rpx; }

/* ---- additional text ---- */
.text-white { color: #fff; }
.text-center { text-align: center; }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 48rpx; }
.text-xxl { font-size: 64rpx; }

/* ---- display ---- */
.w-full { width: 100%; }
.rounded { border-radius: 16rpx; }
.rounded-lg { border-radius: 24rpx; }

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
}

/* ---- cards ---- */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-dark {
  background: linear-gradient(160deg, #141a3a 0%, #0f1330 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid rgba(7, 193, 96, 0.15);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3);
}

/* ---- buttons ---- */
.btn-primary {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border: none;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

/* press animation — scale down on tap */
.btn-primary:active,
.card-dark:active {
  transform: scale(0.97);
  opacity: 0.9;
  transition: transform 0.1s ease, opacity 0.1s ease;
}

/* ---- text utilities ---- */
.text-primary { color: #07c160; }
.text-muted { color: #999; font-size: 24rpx; }
.text-bold { font-weight: 700; }

/* ---- neon text ---- */
.neon-green {
  color: #07c160;
  text-shadow: 0 0 8rpx rgba(7, 193, 96, 0.6), 0 0 24rpx rgba(7, 193, 96, 0.25);
}

.neon-amber {
  color: #f59e0b;
  text-shadow: 0 0 8rpx rgba(245, 158, 11, 0.6), 0 0 24rpx rgba(245, 158, 11, 0.25);
}

.neon-red {
  color: #ef4444;
  text-shadow: 0 0 8rpx rgba(239, 68, 68, 0.6), 0 0 24rpx rgba(239, 68, 68, 0.25);
}

/* ---- tags ---- */
.grade-tag {
  display: inline-block;
  background: #dbeafe;
  color: #2563eb;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.difficulty-tag {
  color: #f59e0b;
  font-size: 24rpx;
}

/* ---- skeleton / loading shimmer ---- */
.skeleton {
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.04) 25%,
    rgba(255, 255, 255, 0.12) 50%,
    rgba(255, 255, 255, 0.04) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 12rpx;
}

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
