/* ========== 首页样式 ========== */

/* ---- 顶部欢迎区 ---- */
.hero-card {
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  position: relative;
  height: auto;
  min-height: 240rpx;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #07c160 0%, #05a348 50%, #04783a 100%);
  z-index: 0;
}

.hero-bg::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.hero-bg::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -50rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.hero-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-greeting {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.hero-emoji {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.hero-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #fff;
  margin-top: 4rpx;
}

.level-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

/* 数据速览 */
.hero-stats {
  display: flex;
  align-items: center;
  margin-top: 32rpx;
  gap: 0;
}

.hs-item {
  flex: 1;
  text-align: center;
}

.hs-num {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}

.hs-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 4rpx;
}

.hs-divider {
  width: 1rpx;
  height: 50rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* 未登录 */
.hero-login {
  margin-top: 28rpx;
  text-align: center;
}

.hero-login-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 16rpx;
}

.btn-login {
  display: inline-block;
  padding: 14rpx 48rpx;
  border-radius: 32rpx;
  background: #fff;
  color: #07c160;
  font-size: 28rpx;
  font-weight: 700;
  border: none;
}

.btn-login::after {
  border: none;
}

/* ---- 今日目标 ---- */
.goal-card {
  padding: 28rpx 32rpx;
}

.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.goal-icon {
  display: none;
}

.goal-text {
  display: flex;
  flex-direction: column;
}

.goal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.goal-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.goal-percent {
  font-size: 36rpx;
  font-weight: 800;
  color: #07c160;
}

.progress-bar {
  height: 12rpx;
  background: #f1f5f9;
  border-radius: 6rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #34d399);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.goal-status {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #6b7280;
}

/* ---- 区块标题 ---- */
.section-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin: 32rpx 0 16rpx;
  padding: 0 4rpx;
}

/* ---- 快捷入口 ---- */
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.action-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #f1f5f9;
  transition: transform 0.1s;
}

.action-card:active {
  transform: scale(0.97);
}

.ac-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}

.speed .ac-icon {
  background: #fff7ed;
}
.thinking .ac-icon {
  background: #eff6ff;
}
.generate .ac-icon {
  background: #f0fdf4;
}
.report .ac-icon {
  background: #faf5ff;
}

.ac-info {
  flex: 1;
  min-width: 0;
}

.ac-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.ac-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.ac-arrow {
  font-size: 32rpx;
  color: #d1d5db;
}

/* ---- 错题提醒 ---- */
.mistake-reminder {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  margin-top: 20rpx;
  border: 1rpx solid #fed7aa;
  background: linear-gradient(135deg, #fffbeb, #fef3c7);
}

.mr-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.mr-body {
  flex: 1;
}

.mr-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
}

.mr-desc {
  font-size: 22rpx;
  color: #b45309;
  margin-top: 4rpx;
}

.mr-go {
  font-size: 24rpx;
  color: #d97706;
  font-weight: 600;
}
