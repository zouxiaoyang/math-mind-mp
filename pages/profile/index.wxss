/* ========== 个人中心 ========== */

/* ---- 顶部用户卡 ---- */
.profile-header {
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  position: relative;
  min-height: 220rpx;
}

.ph-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
}

.ph-bg::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 250rpx;
  height: 250rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.ph-content {
  position: relative;
  z-index: 1;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ph-user {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.ph-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #06ad56);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.ph-avatar-text {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
}

.ph-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.ph-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.ph-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.ph-dot {
  opacity: 0.5;
}
.ph-login-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.ph-login-btn {
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  background: #fff;
  color: #1e293b;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
}

.ph-login-btn::after {
  border: none;
}

/* ---- 数据统计 ---- */
.stats-card {
  padding: 28rpx 16rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
}

.st-item {
  text-align: center;
  padding: 16rpx 8rpx;
}

.st-num {
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.2;
}

.st-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* ---- 卡片标题 ---- */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

/* ---- 成就徽章 ---- */
.badges-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.badge-item {
  text-align: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  background: #f9fafb;
  border: 1rpx solid #f1f5f9;
  opacity: 0.4;
  transition: all 0.3s;
}

.badge-item.unlocked {
  opacity: 1;
  background: #fff;
  border-color: #fde68a;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.1);
}

.badge-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.badge-item:not(.unlocked) .badge-icon {
  filter: grayscale(1);
}

.badge-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.badge-cond {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ---- 菜单 ---- */
.menu-card {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f9fafb;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-badge {
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #fef2f2;
  color: #dc2626;
  font-size: 22rpx;
  font-weight: 600;
}

.menu-arrow {
  font-size: 28rpx;
  color: #d1d5db;
}

/* ---- 版本 ---- */
.version-text {
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}

/* ========== 分享弹窗 ========== */
.share-modal {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.share-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  animation: fadeIn 0.2s ease-out;
}

.share-panel {
  position: relative;
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 180rpx;
  animation: slideUp 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

/* ---- 顶部 ---- */
.share-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx 32rpx 16rpx;
  position: relative;
}

.share-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.share-close {
  position: absolute;
  right: 32rpx;
  top: 24rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  background: #f3f4f6;
  border-radius: 50%;
}

/* ---- 预览卡片 ---- */
.share-card {
  margin: 0 32rpx 32rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f0fdf4 0%, #ecfccb 100%);
  border: 1rpx solid #bbf7d0;
  border-radius: 20rpx;
}

.sc-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.sc-logo {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.sc-info {
  flex: 1;
  min-width: 0;
}

.sc-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #166534;
}

.sc-desc {
  font-size: 24rpx;
  color: #15803d;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-top: 4rpx;
}

.sc-tip {
  text-align: center;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 16rpx;
}

/* ---- 按钮区 ---- */
.share-actions {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
}

.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 16rpx;
  border-radius: 20rpx;
  border: none;
  background: #f9fafb;
  transition: all 0.15s;
}

.share-btn::after {
  border: none;
  border-radius: 20rpx;
}

.sb-icon {
  font-size: 48rpx;
  line-height: 1;
}

.sb-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.share-btn-active {
  background: #e5e7eb;
  transform: scale(0.96);
}

.share-friends {
  background: linear-gradient(135deg, #dcfce7, #bbf7d0);
}

.share-friends .sb-text {
  color: #166534;
}

.share-moments {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
}

.share-moments .sb-text {
  color: #92400e;
}

/* ---- 底部提示 ---- */
.share-hint {
  text-align: center;
  font-size: 22rpx;
  color: #cbd5e1;
  margin-top: 24rpx;
}

/* ---- 动画 ---- */
@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}
