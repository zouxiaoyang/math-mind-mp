<view class="container">
  <view class="card" style="text-align: center;">
    <view style="font-size: 80rpx;">🤖</view>
    <view class="text-bold" style="font-size: 36rpx;">AI 智能出题</view>
    <view class="text-muted mt-s">生成专属题库</view>
  </view>

  <view class="card">
    <view class="text-bold" style="font-size: 32rpx;">设置</view>
    <view class="flex-between" style="padding: 16rpx 0;">
      <text>年级</text>
      <picker mode="selector" range="{{[1,2,3,4,5,6]}}" value="{{grade - 1}}" bindchange="onGradeChange">{{grade}}年级 ›</picker>
    </view>
    <view class="flex-between" style="padding: 16rpx 0;">
      <text>学期</text>
      <picker mode="selector" range="{{['上学期','下学期']}}" value="{{semester - 1}}" bindchange="onSemesterChange">{{semester === 1 ? '上学期' : '下学期'}} ›</picker>
    </view>
    <view class="flex-between" style="padding: 16rpx 0;">
      <text>难度</text>
      <picker mode="selector" range="{{['★','★★','★★★','★★★★','★★★★★']}}" value="{{difficulty - 1}}" bindchange="onDifficultyChange">{{stars}} ›</picker>
    </view>
    <view class="flex-between" style="padding: 16rpx 0;">
      <text>数量</text>
      <picker mode="selector" range="{{[1,3,5,10,20]}}" value="{{2}}" bindchange="onCountChange">{{count}}题 ›</picker>
    </view>
  </view>

  <button class="btn-primary" style="width: 100%; background: {{loading ? '#94a3b8' : 'linear-gradient(135deg, #07c160, #06ad56)'}}; opacity: {{loading ? 0.7 : 1}};" bindtap="handleGenerate" disabled="{{loading}}">
    {{loading ? '⏳ 生成中...' : '✨ 一键生成 ' + count + ' 题'}}
  </button>

  <view class="card" wx:if="{{result}}">
    <view class="text-bold" style="font-size: 32rpx;">生成结果</view>
    <view class="flex-between mt-m">
      <text>方式</text>
      <text class="grade-tag">{{result.method === 'ai' ? 'AI生成' : '模板生成'}}</text>
    </view>
    <view class="flex-between mt-s">
      <text>成功</text>
      <text class="text-primary text-bold">{{result.created}} 题</text>
    </view>
    <view class="flex-between mt-s">
      <text>跳过</text>
      <text class="text-muted">{{result.skipped}} 题</text>
    </view>
    <view wx:for="{{result.questions}}" wx:key="id" class="mt-s" style="padding: 12rpx; background: #f5f5f5; border-radius: 12rpx;">
      <text style="font-size: 28rpx;">{{item.title}}</text>
    </view>
  </view>
</view>
