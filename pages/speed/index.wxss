/* ===== SPEED ARCADE THEME ===== */
.speed-page {
  min-height: 100vh;
  background: #0a0e27;
  position: relative;
  overflow: hidden;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

/* ===== IDLE STATE ===== */
.idle-bg {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background:
    radial-gradient(ellipse at 50% 50%, rgba(7, 193, 96, 0.08) 0%, transparent 60%),
    radial-gradient(ellipse at 20% 80%, rgba(245, 158, 11, 0.06) 0%, transparent 50%);
  animation: bgPulse 4s ease-in-out infinite;
}

@keyframes bgPulse {
  0%,
  100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

.idle-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.logo-burst {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid rgba(7, 193, 96, 0.3);
  animation: ringExpand 2s ease-out infinite;
}

.logo-ring::before {
  content: '';
  position: absolute;
  inset: 20rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(7, 193, 96, 0.2);
  animation: ringExpand 2s ease-out 0.5s infinite;
}

@keyframes ringExpand {
  0% {
    transform: scale(0.8);
    opacity: 1;
  }
  100% {
    transform: scale(1.4);
    opacity: 0;
  }
}

.logo-core {
  font-size: 100rpx;
  animation: logoBounce 2s ease-in-out infinite;
  filter: drop-shadow(0 0 20rpx rgba(7, 193, 96, 0.6));
}

@keyframes logoBounce {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

.title-main {
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  text-shadow: 0 0 40rpx rgba(7, 193, 96, 0.4);
}

.title-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

.config-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 60rpx;
  box-sizing: border-box;
  backdrop-filter: blur(10px);
}

.config-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.config-row:last-child {
  margin-bottom: 0;
}

.config-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  width: 80rpx;
  flex-shrink: 0;
}

.grade-chips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  flex: 1;
}

.grade-chip {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.grade-chip.active {
  background: rgba(7, 193, 96, 0.2);
  border-color: #07c160;
  color: #07c160;
  font-weight: 600;
  box-shadow: 0 0 16rpx rgba(7, 193, 96, 0.3);
}

.difficulty-bar {
  display: flex;
  gap: 16rpx;
  flex: 1;
}

.diff-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.2s;
}

.diff-dot.active {
  background: #f59e0b;
  border-color: #f59e0b;
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.5);
}

.difficulty-label {
  font-size: 24rpx;
  color: #f59e0b;
  width: 140rpx;
  text-align: right;
}

.start-btn {
  width: 100%;
  margin-top: 60rpx;
  background: none;
  border: none;
  padding: 0;
}

.start-btn-inner {
  background: linear-gradient(135deg, #07c160, #05a348);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  padding: 28rpx;
  border-radius: 56rpx;
  text-align: center;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.4);
  transition: all 0.2s;
}

.start-btn-inner:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

/* ===== PLAYING STATE ===== */
.hud {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  position: relative;
  z-index: 2;
}

.timer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
}

.timer-icon {
  font-size: 28rpx;
}

.timer-value {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  font-variant-numeric: tabular-nums;
  min-width: 50rpx;
  text-align: center;
}

.timer.danger .timer-value {
  color: #fa5151;
  animation: timerPulse 0.5s ease-in-out infinite;
}

@keyframes timerPulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0.5;
  }
}

.combo {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.06);
}

.combo.hot {
  background: rgba(245, 158, 11, 0.15);
  animation: comboGlow 0.8s ease-in-out infinite;
}

@keyframes comboGlow {
  0%,
  100% {
    box-shadow: 0 0 8rpx rgba(245, 158, 11, 0.3);
  }
  50% {
    box-shadow: 0 0 20rpx rgba(245, 158, 11, 0.6);
  }
}

.combo-flame {
  font-size: 32rpx;
  animation: flameWiggle 0.3s ease-in-out infinite;
}

@keyframes flameWiggle {
  0%,
  100% {
    transform: rotate(-5deg);
  }
  50% {
    transform: rotate(5deg);
  }
}

.combo-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #f59e0b;
}

.score-live {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(255, 255, 255, 0.08);
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
}

.time-bar-wrap {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.06);
  margin: 0 32rpx;
  border-radius: 3rpx;
  overflow: hidden;
}

.time-bar {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #06ad56);
  border-radius: 3rpx;
  transition: width 1s linear;
}

.time-bar.danger {
  background: linear-gradient(90deg, #fa5151, #ff6b6b);
}

.problem-area {
  padding: 60rpx 32rpx 32rpx;
  position: relative;
  z-index: 2;
}

.problem-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 32rpx;
  padding: 60rpx 32rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.15s;
}

.problem-card.pop-correct {
  animation: popCorrect 0.4s ease-out;
  border-color: rgba(7, 193, 96, 0.5);
}

.problem-card.shake-wrong {
  animation: shakeWrong 0.4s ease-out;
  border-color: rgba(250, 81, 81, 0.5);
}

@keyframes popCorrect {
  0% {
    transform: scale(1);
  }
  30% {
    transform: scale(1.03);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes shakeWrong {
  0%,
  100% {
    transform: translateX(0);
  }
  20% {
    transform: translateX(-12rpx);
  }
  40% {
    transform: translateX(12rpx);
  }
  60% {
    transform: translateX(-8rpx);
  }
  80% {
    transform: translateX(8rpx);
  }
}

.problem-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.problem-num {
  font-size: 80rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 0 20rpx rgba(255, 255, 255, 0.2);
}

.problem-op {
  font-size: 60rpx;
  font-weight: 600;
  color: #07c160;
  margin: 0 8rpx;
}

.problem-eq {
  font-size: 60rpx;
  color: rgba(255, 255, 255, 0.4);
  margin: 0 8rpx;
}

.problem-ans {
  font-size: 80rpx;
  font-weight: 800;
  color: #f59e0b;
  min-width: 120rpx;
  text-align: center;
  text-shadow: 0 0 20rpx rgba(245, 158, 11, 0.3);
}

.feedback-burst {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 200rpx;
  font-weight: 900;
  opacity: 0;
  animation: feedbackPop 0.5s ease-out forwards;
  pointer-events: none;
}

.feedback-burst.correct {
  color: #07c160;
}

.feedback-burst.wrong {
  color: #fa5151;
}

@keyframes feedbackPop {
  0% {
    opacity: 0.8;
    transform: translate(-50%, -50%) scale(0.5);
  }
  100% {
    opacity: 0;
    transform: translate(-50%, -50%) scale(1.5);
  }
}

.input-area {
  padding: 0 32rpx;
  display: flex;
  gap: 16rpx;
  position: relative;
  z-index: 2;
}

.answer-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  height: 88rpx;
  box-sizing: border-box;
}

.answer-input:focus {
  border-color: #07c160;
  box-shadow: 0 0 20rpx rgba(7, 193, 96, 0.2);
}

.submit-btn {
  background: linear-gradient(135deg, #07c160, #05a348);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 24rpx;
  border: none;
  padding: 24rpx 40rpx;
  height: 88rpx;
  line-height: 40rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.submit-btn::after {
  border: none;
}

/* ===== 自定义街机键盘 ===== */
.answer-display {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #f59e0b;
  text-align: center;
  height: 88rpx;
  line-height: 40rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  text-shadow: 0 0 20rpx rgba(245, 158, 11, 0.3);
}

.answer-placeholder {
  color: rgba(255, 255, 255, 0.3);
  text-shadow: none;
}

.arcade-keypad {
  padding: 16rpx 32rpx 32rpx;
  position: relative;
  z-index: 2;
}

.keypad-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.keypad-row:last-child {
  margin-bottom: 0;
}

.key {
  flex: 1;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  transition: all 0.1s;
}

.key:active {
  background: rgba(7, 193, 96, 0.3);
  border-color: #07c160;
  transform: scale(0.95);
  box-shadow: 0 0 20rpx rgba(7, 193, 96, 0.3);
}

.key-back {
  background: rgba(255, 255, 255, 0.04);
  color: rgba(255, 255, 255, 0.5);
  font-size: 36rpx;
}

.key-back:active {
  background: rgba(250, 81, 81, 0.2);
  border-color: #fa5151;
  color: #fa5151;
}

.key-enter {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.3), rgba(6, 173, 86, 0.3));
  border-color: rgba(7, 193, 96, 0.5);
  color: #07c160;
  font-size: 36rpx;
}

.key-enter:active {
  background: linear-gradient(135deg, #07c160, #05a348);
  color: #fff;
  box-shadow: 0 0 24rpx rgba(7, 193, 96, 0.5);
}

/* ===== FINISHED STATE ===== */
.result-bg {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.confetti {
  position: absolute;
  top: -20rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 2rpx;
  animation: confettiFall 3s linear infinite;
}

@keyframes confettiFall {
  0% {
    transform: translateY(-20rpx) rotate(0deg);
    opacity: 1;
  }
  100% {
    transform: translateY(100vh) rotate(720deg);
    opacity: 0;
  }
}

.result-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.result-badge {
  font-size: 140rpx;
  animation: badgeReveal 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
}

@keyframes badgeReveal {
  0% {
    transform: scale(0) rotate(-30deg);
    opacity: 0;
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.result-score {
  font-size: 120rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 0 40rpx rgba(7, 193, 96, 0.5);
  animation: scoreCount 0.8s ease-out 0.4s both;
}

@keyframes scoreCount {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  60% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.result-unit {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: -10rpx;
  margin-bottom: 60rpx;
}

.result-stats {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx 0;
  width: 100%;
  margin-bottom: 60rpx;
  animation: fadeUp 0.5s ease-out 0.6s both;
}

@keyframes fadeUp {
  0% {
    transform: translateY(30rpx);
    opacity: 0;
  }
  100% {
    transform: translateY(0);
    opacity: 1;
  }
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-val {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
}

.stat-lbl {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
}
