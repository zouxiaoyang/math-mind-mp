/* thinking.wxss */
.input {
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  width: 100%;
  box-sizing: border-box;
  background: #fff;
}

/* 能力值标签 */
.theta-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #eff6ff, #f5f3ff);
  border-radius: 16rpx;
  border: 2rpx solid #e0e7ff;
}

.theta-label {
  font-size: 22rpx;
  color: #6b7280;
}

.theta-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2563eb;
}

.theta-stars {
  font-size: 24rpx;
  color: #f59e0b;
}

/* AI 批改进度条 */
.progress-wrap {
  margin-top: 24rpx;
  padding: 0 8rpx;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #10b981);
  border-radius: 8rpx;
  transition: width 0.4s ease;
}

.progress-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
}
