/* thinking.wxss */
.input {
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  width: 100%;
  box-sizing: border-box;
  background: #fff;
}

/* AI 批改进度条 */
.progress-wrap {
  margin-top: 24rpx;
  padding: 0 8rpx;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #10b981);
  border-radius: 8rpx;
  transition: width 0.4s ease;
}

.progress-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #9ca3af;
  text-align: center;
}
